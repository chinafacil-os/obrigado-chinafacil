# ============================================================================
# Renomeie este arquivo para ".env.local" e preencha os valores.
# ============================================================================

# ID do Pixel do Meta (Gerenciador de Eventos > Configurações).
# Exposto no navegador (precisa do prefixo NEXT_PUBLIC_).
NEXT_PUBLIC_META_PIXEL_ID=

# Token de acesso da Conversions API (CAPI).
# Gerenciador de Eventos > seu Pixel > Configurações > Conversions API >
# "Gerar token de acesso". NUNCA exponha esse token no navegador.
# Enquanto estiver vazio, o envio server-side (CAPI) é pulado automaticamente.
META_CAPI_TOKEN=

# Nome do evento personalizado, idêntico no Pixel e na CAPI.
NEXT_PUBLIC_META_EVENT_NAME=ImportaCF

# Link do grupo de WhatsApp (ex.: https://chat.whatsapp.com/XXXXXXXXXXXX).
# Exposto no navegador para o redirecionamento e o botão.
NEXT_PUBLIC_WHATSAPP_GROUP_URL=https://chat.whatsapp.com/SEU-LINK-AQUI

# (Opcional) Código de teste do Gerenciador de Eventos para validar a CAPI
# na aba "Testar eventos". Remova em produção.
META_TEST_EVENT_CODE=
